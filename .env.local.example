# Supabase — create a project at https://supabase.com and copy these from
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only key (used by API routes for admin operations such as account deletion).
# NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# MapTiler — free tier key from https://www.maptiler.com (satellite tiles)
NEXT_PUBLIC_MAPTILER_KEY=your-maptiler-key

# Public base URL of the app (used for invite links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
